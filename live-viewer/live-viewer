def parse_args(argv):
    ap = argparse.ArgumentParser(
        description="Fast live viewer for CSV values arriving on stdin.")
    ap.add_argument("--style", choices=["lines", "points", "linespoints"],
                    default="linespoints",
                    help="how to draw each channel (default: linespoints)")
    ap.add_argument("--group", action="append", default=[],
                    help="define a plot group; may be given multiple times. "
                         "A group is either a set of 1-based column "
                         "numbers/ranges (e.g. '4-9' or '1,3,5'), a wildcard "
                         "matching header column names (e.g. 'snc*', 'a*'), or "
                         "a channel token (e.g. 'imu') selecting rows by their "
                         "channel column.")
    ap.add_argument("--shared-range-groups", default="",
                    help="comma-separated 1-based indices of groups (top to "
                         "bottom) that should share a common min/max across all "
                         "their channels, e.g. '1,3,4'.")
    ap.add_argument("--width", type=parse_duration, default=None,
                    help="width of the rolling time window to display; older "
                         "data is rolled out. Accepts e.g. 500ms, 3s, 2m, 1h. "
                         "If given multiple times only the last is used. "
                         "Without it, the full history is shown.")
    return ap.parse_args(argv)


def read_sample(nrows=400):
    """Read the header (if any) plus some sample rows for structure guessing,
    without losing them from the stream."""
    lines = []
    for _ in range(nrows):
        line = sys.stdin.readline()
        if not line:
            break
        lines.append(line.rstrip("\n").rstrip("\r"))
    return lines


class PrereadStdin:
    """Iterable yielding pre-read sample lines first, then the live stream."""
    def __init__(self, buffered_lines, real):
        self._buf = buffered_lines
        self._real = real

    def __iter__(self):
        for l in self._buf:
            yield l
        for l in self._real:
            yield l


def main():
    args = parse_args(sys.argv[1:])

    sample_lines = read_sample()
    if not sample_lines:
        sys.stderr.write("live-viewer: no input on stdin\n")
        return 1

    split_rows = [l.split(",") for l in sample_lines]

    header = None
    data_lines = sample_lines
    data_rows = split_rows
    if is_header_row(split_rows[0]):
        header = [h.strip() for h in split_rows[0]]
        data_rows = split_rows[1:]
        data_lines = sample_lines[1:]

    st = guess_structure(header, data_rows)
    sys.stderr.write(st.describe() + "\n")
    if st.ts_col is not None:
        sys.stderr.write("Timestamp column: %d (%s)\n" %
                         (st.ts_col + 1, "ISO" if st.ts_is_iso else "numeric"))
    sys.stderr.flush()

    specs = [GroupSpec(g) for g in args.group]
    groups, titles, plan = build_groups(st, specs, data_rows)

    shared = []
    if args.shared_range_groups.strip():
        for tok in args.shared_range_groups.split(","):
            tok = tok.strip()
            if tok.isdigit():
                shared.append(int(tok) - 1)  # 1-based -> 0-based

    # Reader replays the buffered DATA lines first, then the live stdin.
    line_source = PrereadStdin(list(data_lines), sys.stdin)
    reader = Reader(st, plan, line_source)
    reader.start()

    run_gui(st, groups, titles, reader, shared, args.style, args.width)
    reader.stop_flag = True
    return 0


if __name__ == "__main__":
    sys.exit(main())
